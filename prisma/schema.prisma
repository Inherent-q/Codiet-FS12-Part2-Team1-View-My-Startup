generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Corp {
  id                   Int                   @id @default(autoincrement())
  name                 String
  description          String
  category             String
  accInvest            BigInt
  revenue              BigInt
  hire                 Int
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  img                  String?
  comparisonselections Comparisonselection[]
  investors            Investor[]
  myselections         Myselection[]
}

model Investor {
  id        Int      @id @default(autoincrement())
  name      String
  amount    BigInt
  password  String
  comment   String
  corpId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  corp      Corp     @relation(fields: [corpId], references: [id])
}

model Comparisonselection {
  id            Int      @id @default(autoincrement())
  userSessionId String
  corpId        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  corp          Corp     @relation(fields: [corpId], references: [id])
}

model Myselection {
  id            Int      @id @default(autoincrement())
  userSessionId String
  corpId        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  corp          Corp     @relation(fields: [corpId], references: [id])
}
